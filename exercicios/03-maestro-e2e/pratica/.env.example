# Copie este arquivo pra .env (sem .example) e cole seu token TMDB.
# .env está no .gitignore — NUNCA comite tokens reais.
#
# OPCIONAL: sem token, o app roda com dados MOCKADOS (filmes fixos) — suficiente
# pra Atividade 3. Configure o token só se quiser ver filmes REAIS da TMDB.
#
# Gerar token: https://www.themoviedb.org/settings/api
# Aceita os 2 formatos (detecta automático):
#   - API Key v3 (32 chars hex):           EXPO_PUBLIC_TMDB_TOKEN=828ce092ac...
#   - API Read Access Token v4 (JWT longo): EXPO_PUBLIC_TMDB_TOKEN=eyJhbGc...

EXPO_PUBLIC_TMDB_TOKEN=cole_seu_token_aqui
